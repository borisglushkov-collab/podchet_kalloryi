[Unit]
Description=Podchet Kalloriy FastAPI Backend
After=network.target

[Service]
Type=simple
User=podchet
Group=podchet
WorkingDirectory=/opt/podchet_kalloriy/backend
EnvironmentFile=/opt/podchet_kalloriy/backend/.env
ExecStart=/opt/podchet_kalloriy/backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
