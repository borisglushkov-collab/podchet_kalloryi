# OAuth-токен Яндекс.Диска
# Получить: https://yandex.ru/dev/disk/poligon/ → «Получить OAuth-токен»
# Документация: https://yandex.ru/dev/disk/api/concepts/quickstart.html

YANDEX_DISK_TOKEN=

# Папка на Диске (создаётся автоматически).
# Используйте disk:/... — файл будет виден в корне Диска.
# app:/... кладёт в «Приложения / <имя OAuth-приложения>/...» и его легко не заметить.
YANDEX_DISK_FOLDER=disk:/podchet_kalloriy/apk
